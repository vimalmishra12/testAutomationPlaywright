# Playwright MCP design-time tooling — browser/session artifacts must never be committed
tooling/playwright-mcp/.profile/
tooling/playwright-mcp/screenshots/
tooling/playwright-mcp/node_modules/

# General node_modules
node_modules/

# Allure and test output artifacts
allure-results/
allure-report/
output/
logs/
local.log

# Playwright migration (Prompt 4) run artefacts — never commit
traces/
mochawesome-report/
test/tempRunner/

# Visual regression artefacts — NOT committed. Each environment / CI runner
# (e.g. Semaphore) and each engineer generates and owns their own baselines
# locally (first --visual=novus run bootstraps them). This avoids cross-machine
# rendering diffs being committed as "the" baseline.
screenshots/baseline/
screenshots/screen/
screenshots/diff/

# Credential-bearing env backups must never be committed (env.json itself is tracked
# with placeholders; real creds belong in env vars LT_USERNAME / LT_ACCESS_KEY)
env copy.json
env.local.json
env.*.local.json
